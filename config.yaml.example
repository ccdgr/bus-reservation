server:
  port: ":8080"

mysql:
  dsn: "user:password@tcp(127.0.0.1:3306)/bus_reservation?charset=utf8mb4&parseTime=True&loc=Local"

redis:
  addr: "127.0.0.1:6379"
  password: ""
  db: 0

rabbitmq:
  url: "amqp://guest:guest@localhost:5672/"

paypal:
  client_id: "your_paypal_client_id"
  secret: "your_paypal_secret"
  return_url: "http://localhost:8080/api/v1/payments/paypal/capture"
  cancel_url: "http://localhost:5174/orders"
