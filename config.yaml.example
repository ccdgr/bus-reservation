server:
  port: ":8080"

mysql:
  dsn: "user:password@tcp(127.0.0.1:3306)/bus_reservation?charset=utf8mb4&parseTime=True&loc=Local"

redis:
  addr: "127.0.0.1:6379"
  password: ""
  db: 0

rabbitmq:
  url: "amqp://guest:guest@localhost:5672/"

alipay:
  app_id: "your_sandbox_app_id"
  private_key: "your_app_private_key"
  alipay_public_key: "alipay_public_key"
  notify_url: "http://your-domain.com/api/v1/payments/alipay/notify"
  return_url: "http://your-domain.com/orders"
